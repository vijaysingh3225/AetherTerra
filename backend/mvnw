# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup script, version 3.3.2
# ----------------------------------------------------------------------------

# If JAVA_HOME is set, use it; otherwise look for java in PATH
if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

# Resolve the wrapper properties file
MAVEN_WRAPPER_PROPERTIES="./.mvn/wrapper/maven-wrapper.properties"

# Download URL from properties
DOWNLOAD_URL=$(grep '^wrapperUrl' "$MAVEN_WRAPPER_PROPERTIES" | cut -d= -f2- | tr -d '[:space:]')
DISTRIBUTION_URL=$(grep '^distributionUrl' "$MAVEN_WRAPPER_PROPERTIES" | cut -d= -f2- | tr -d '[:space:]')

# Maven home in user cache
MAVEN_USER_HOME="${MAVEN_USER_HOME:-$HOME/.m2}"
WRAPPER_JAR="$MAVEN_USER_HOME/wrapper/dists/$(basename "$DISTRIBUTION_URL" .zip)/maven-wrapper.jar"

# Download wrapper jar if absent
if [ ! -f "$WRAPPER_JAR" ]; then
    mkdir -p "$(dirname "$WRAPPER_JAR")"
    if command -v curl > /dev/null; then
        curl -fsSL -o "$WRAPPER_JAR" "$DOWNLOAD_URL"
    elif command -v wget > /dev/null; then
        wget -q -O "$WRAPPER_JAR" "$DOWNLOAD_URL"
    else
        echo "ERROR: Neither curl nor wget found. Cannot download Maven wrapper." >&2
        exit 1
    fi
fi

exec "$JAVACMD" \
    -classpath "$WRAPPER_JAR" \
    "-Dmaven.multiModuleProjectDirectory=$MAVEN_WRAPPER_PROJECTBASEDIR" \
    org.apache.maven.wrapper.MavenWrapperMain "$@"

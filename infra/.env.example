# -----------------------------------------------------------------------
# Aether Terra — environment variable reference
# Copy this file to .env (never commit .env) and fill in real values.
# -----------------------------------------------------------------------

# --- PostgreSQL (matches docker-compose defaults for local dev) ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=aetherterra
DB_USER=aetherterra
DB_PASSWORD=aetherterra

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# --- JWT (generate a strong random secret before first use) ---
JWT_SECRET=change-me-before-deploying
JWT_EXPIRY_SECONDS=3600

# --- Mail (points to local Mailpit in dev; set real SMTP values in prod) ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@aetherterra.local

# --- Stripe ---
# Get these from https://dashboard.stripe.com/apikeys
# Leave blank locally to run in mock mode (no real Stripe calls).
# In production all three are required.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook URL to register in Stripe dashboard (or Stripe CLI for local testing):
#   https://your-domain.com/api/v1/webhooks/stripe
# For local dev:
#   stripe listen --forward-to localhost:8080/api/v1/webhooks/stripe

# --- Shopify ---
# Get these from your Shopify admin: Settings > Apps > Develop apps
# Leave blank (or set SHOPIFY_MOCK_MODE=true) for local dev.
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2025-01
SHOPIFY_MOCK_MODE=true

# --- Frontend (Vite exposes VITE_* vars to the browser) ---
VITE_API_BASE_URL=http://localhost:8080
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

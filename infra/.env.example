# -----------------------------------------------------------------------
# Aether Terra — environment variable reference
# Copy this file to .env (never commit .env) and fill in real values.
# -----------------------------------------------------------------------

# --- PostgreSQL (matches docker-compose defaults for local dev) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aetherterra
DB_USER=aetherterra
DB_PASSWORD=aetherterra

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# --- JWT (generate a strong random secret before first use) ---
JWT_SECRET=change-me-before-deploying
JWT_EXPIRY_SECONDS=3600

# --- Mail (points to local Mailpit in dev) ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@aetherterra.local

# --- Stripe (integration pending) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Shopify (integration pending) ---
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_ADMIN_API_TOKEN=shpat_...

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080

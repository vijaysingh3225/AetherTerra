# -----------------------------------------------------------------------
# Aether Terra — environment variable reference
# Copy this file to .env (never commit .env) and fill in real values.
# -----------------------------------------------------------------------

# --- PostgreSQL (matches docker-compose defaults for local dev) ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=aetherterra
DB_USER=aetherterra
DB_PASSWORD=aetherterra

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# --- JWT (generate a strong random secret before first use) ---
JWT_SECRET=change-me-before-deploying
JWT_EXPIRY_SECONDS=3600

# --- Mail (points to local Mailpit in dev; set real SMTP values in prod) ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@aetherterra.local

# --- Stripe ---
# Get keys from https://dashboard.stripe.com/apikeys (use test-mode keys locally).
# Leave ALL three blank to run in mock mode (no real Stripe calls).
# In production all three are required.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Local webhook testing with Stripe CLI:
#   1. stripe listen --forward-to localhost:8080/api/v1/webhooks/stripe
#      (prints a whsec_... signing secret — paste it as STRIPE_WEBHOOK_SECRET above)
#   2. In a second terminal: stripe trigger setup_intent.succeeded
# Test card: 4242 4242 4242 4242  exp: any future date  CVC: any 3 digits

# --- Shopify ---
# Get these from your Shopify admin: Settings > Apps > Develop apps
# Leave blank (or set SHOPIFY_MOCK_MODE=true) for local dev.
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2025-01
SHOPIFY_MOCK_MODE=true
# Webhook secret used to verify X-Shopify-Hmac-Sha256 signatures.
# Set in Shopify admin: Settings > Notifications > Webhooks > your webhook > Signing Secret.
# Leave blank locally to skip verification (mock/dev mode — never blank in production).
SHOPIFY_WEBHOOK_SECRET=
# Webhook URL to register in Shopify (Settings > Notifications > Webhooks):
#   Topic: Order payment / orders/paid
#   URL:   https://your-domain.com/api/v1/webhooks/shopify

# --- Payment deadline ---
# How many hours after auction end the winner has to complete checkout before the
# order is automatically marked EXPIRED. Default is 24 hours.
PAYMENT_DUE_HOURS=24

# --- Frontend (Vite exposes VITE_* vars to the browser) ---
VITE_API_BASE_URL=http://localhost:8080
# Must match STRIPE_PUBLISHABLE_KEY above. Leave blank for mock mode.
VITE_STRIPE_PUBLISHABLE_KEY=

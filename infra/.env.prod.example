# Copy to infra/.env.prod and fill in real values before deploying.
# NEVER commit .env.prod to git.

# PostgreSQL
POSTGRES_DB=aetherterra
POSTGRES_USER=aetherterra
POSTGRES_PASSWORD=change_me_strong_password

# JWT — must be at least 32 random characters
JWT_SECRET=change_me_to_a_long_random_secret_string_here
JWT_EXPIRY_SECONDS=86400

# Transactional email (e.g. SendGrid, Postmark, AWS SES)
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your_smtp_api_key
MAIL_FROM=noreply@aetherterra.com

# Public base URL for email verification links
APP_BASE_URL=https://aetherterra.com
